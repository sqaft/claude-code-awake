{
	"hooks": {
		"UserPromptSubmit": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/start-caffeinate.sh",
						"timeout": 5
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-caffeinate.sh",
						"timeout": 5
					}
				]
			}
		],
		"SessionEnd": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/cleanup-caffeinate.sh",
						"timeout": 2
					}
				]
			}
		]
	}
}
